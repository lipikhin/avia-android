<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: no cloud backup / device transfer — the encrypted auth prefs
     are useless without the device-bound Keystore key and crash on restore. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
